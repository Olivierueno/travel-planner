# Shared password for trip access
TRIP_PASSWORD=your-shared-password

# Secret for signing auth tokens (generate a random string)
AUTH_SECRET=generate-a-random-secret-here

# Google Maps Embed API key (free, no billing required)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Maps Embed API" on your project
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Vercel KV (automatically set when you link a KV store in Vercel)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
